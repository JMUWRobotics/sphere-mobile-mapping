<launch>
  <!-- Launch file for Global Ground Finder -->
  <!-- Computes ground normal from global map at current pose -->

  <!-- Arguments -->
  <arg name="quiet" default="false" 
       doc="Suppress verbose logging"/>
  
  <arg name="plane_algorithm" default="ransac" 
       doc="Plane fitting algorithm: 'pca', 'ransac', 'rht', or 'rht2'"/>
  
  <arg name="extraction_radius" default="2.0" 
       doc="Radius [m] for local map extraction around pose"/>
  
  <arg name="extraction_height" default="0.5" 
       doc="Height limit [m] for vertical filtering around pose"/>
  
  <arg name="enable_scoring" default="true" 
       doc="Enable quality scoring and fallback mechanism"/>
  
  <arg name="score_threshold" default="0.2" 
       doc="Minimum score to accept current normal (else use fallback)"/>
  
  <arg name="min_score_window" default="0.3" 
       doc="Minimum acceptable score from history window"/>

  <arg name="pose_topic" default="/lkf/pose" 
       doc="Topic for robot pose (geometry_msgs/PoseStamped in map_lkf frame)"/>

  <!-- Smoothing parameters -->
  <arg name="enable_normal_smoothing" default="true" 
       doc="Enable smoothing of normal vectors"/>
  
  <arg name="use_gaussian_smoothing" default="false" 
       doc="Use Gaussian kernel smoothing (true) or EMA (false)"/>
  
  <arg name="normal_smoothing_alpha" default="0.1" 
       doc="EMA smoothing factor [0,1]: higher=more responsive, lower=smoother"/>
  
  <arg name="smoothing_cutoff_freq" default="2.0" 
       doc="Gaussian kernel cutoff frequency (Hz)"/>
  
  <arg name="update_rate" default="20.0" 
       doc="Expected normal update rate (Hz) for Gaussian kernel"/>

  <arg name="file" default="default"
       doc="CSV log filename. Use 'default' to disable logging."/>

  <arg name="debug_publish" default="false"
       doc="Publish rejected intermediate inlier clouds for debugging"/>

  <!-- Validation layer parameters -->
  <arg name="enable_eigenvalue_validation" default="false"
       doc="Enable eigenvalue ratio and eigenvector z-component checks"/>
  
  <arg name="eigenvalue_ratio_threshold" default="0.1"
       doc="Threshold for λ3/(λ1+λ2) planarity check"/>
  
  <arg name="max_eigenvector_z_component" default="0.1"
       doc="Max z-component of dominant eigenvectors (v1, v2). Lower = stricter wall rejection."/>
  
  <arg name="enable_plane_angle_validation" default="true"
       doc="Enable angle-based wall rejection"/>
  
  <arg name="enable_z_mean_validation" default="false"
       doc="Enable Z-mean deviation check"/>
  
  <arg name="max_z_deviation" default="0.1"
       doc="Max deviation of Z-mean from robot Z [m]. Also limits vertical spread (z-spread max = 2x this value)."/>
  
  <arg name="enable_convex_hull_validation" default="false"
       doc="Enable convex hull center distance check"/>
  
  <arg name="max_hull_distance" default="0.3"
       doc="Max 3D distance from robot to hull center [m]"/>

     <arg name="manager" default="LIO_GF_nodelet_manager"
       doc="Name of the nodelet manager process"/>

  <arg name="start_manager" default="false"
       doc="Start a local manager in this launch file; set true if nodelet should run as standalone"/>

  <node pkg="nodelet"
        type="nodelet"
        name="$(arg manager)"
        args="manager"
        output="screen"
        if="$(arg start_manager)"/>

  <!-- Nodelet -->
  <node name="global_ground_finder_node"
        pkg="nodelet"
        type="nodelet"
        args="load global_ground_finder/GlobalGroundFinderNodelet $(arg manager)"
        output="screen">
    
    <!-- Basic parameters -->
    <param name="quiet" type="bool" value="$(arg quiet)"/>
    <param name="plane_algorithm" type="string" value="$(arg plane_algorithm)"/>
    
    <!-- Extraction parameters -->
    <param name="extraction_radius" type="double" value="$(arg extraction_radius)"/>
    <param name="extraction_height" type="double" value="$(arg extraction_height)"/>
    <param name="min_points_for_plane" type="double" value="10.0"/>
    
    <!-- Plane validation -->
    <param name="wall_threshold" type="double" value="0.707"/>  <!-- cos(45°) -->
    <param name="max_iterations_plane_detection" type="int" value="3"/>
    
    <!-- Scoring parameters -->
    <param name="enable_scoring" type="bool" value="$(arg enable_scoring)"/>
    <param name="score_threshold" type="double" value="$(arg score_threshold)"/>
    <param name="min_score_window" type="double" value="$(arg min_score_window)"/>
    <param name="weight_visibility" type="double" value="0.6"/>
    <param name="weight_inlier_ratio" type="double" value="0.4"/>
    <param name="min_inliers" type="double" value="10.0"/>
    <param name="inlier_scale" type="double" value="0.3"/>

    <!-- Validation layer parameters -->
    <param name="enable_eigenvalue_validation" type="bool" value="$(arg enable_eigenvalue_validation)"/>
    <param name="eigenvalue_ratio_threshold" type="double" value="$(arg eigenvalue_ratio_threshold)"/>
    <param name="max_eigenvector_z_component_" type="double" value="$(arg max_eigenvector_z_component)"/>
    <param name="enable_plane_angle_validation" type="bool" value="$(arg enable_plane_angle_validation)"/>
    <param name="enable_z_mean_validation" type="bool" value="$(arg enable_z_mean_validation)"/>
    <param name="max_z_deviation" type="double" value="$(arg max_z_deviation)"/>
    <param name="enable_convex_hull_validation" type="bool" value="$(arg enable_convex_hull_validation)"/>
    <param name="max_hull_distance" type="double" value="$(arg max_hull_distance)"/>

    <!-- Smoothing parameters -->
    <param name="enable_normal_smoothing" type="bool" value="$(arg enable_normal_smoothing)"/>
    <param name="use_gaussian_smoothing" type="bool" value="$(arg use_gaussian_smoothing)"/>
    <param name="normal_smoothing_alpha" type="double" value="$(arg normal_smoothing_alpha)"/>
    <param name="smoothing_cutoff_freq" type="double" value="$(arg smoothing_cutoff_freq)"/>
    <param name="update_rate" type="double" value="$(arg update_rate)"/>

    <!-- File logging -->
    <param name="file" type="string" value="$(arg file)"/>
          <param name="debug_publish" type="bool" value="$(arg debug_publish)"/>

  </node>

</launch>
