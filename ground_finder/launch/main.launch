<launch>
  <!-- list of arguments that can be given as inputs of the launch file -->
  <arg name="gf_quiet"     default="false" />
  <arg name="gf_filter"    default="geo" />
  <arg name="gf_subcloud"  default="geo" />
  <arg name="gf_plane"     default="ran" />
  <arg name="gf_file"      default="default" />
  <arg name="gf_enable_normal_smoothing" default="true" />
  <arg name="gf_normal_smoothing_alpha" default="0.1" />   <!-- [0,...,1] higher: more responsive, lower: smoother -->
  <arg name="gf_smoothing_cutoff_freq" default="2.0" />    <!-- cut off freq for gaussian kernel smoothing: 1Hz means signals with trends that take >1s to complete cycle pass while filtering out higher freq. changes  -->
  <arg name="gf_use_gaussian_smoothing" default="true" />
  <arg name="gf_enable_scoring" default="true"/>     <!-- bool to disable scoring of normal vector and fallback mechanism-->
  <arg name="gf_wall_threshold" default="0.707" />
  <arg name="gf_enable_eigenvalue_validation" default="false" />
  <arg name="gf_eigenvalue_ratio_threshold" default="0.1" />
  <arg name="gf_max_eigenvector_z_component" default="0.1" />
  <arg name="gf_enable_plane_angle_validation" default="true" />
  <arg name="gf_enable_z_mean_validation" default="false" />
  <arg name="gf_max_z_deviation" default="0.2" />
  <arg name="gf_enable_convex_hull_validation" default="false" />
  <arg name="gf_max_hull_distance" default="1.0" />
  <arg name="gf_timing_csv_enabled" default="true" />
  <arg name="gf_timing_csv_file" default="$(env HOME)/catkin_ws/src/ground_finder/data/timings.csv" />

  <!-- C++ Executables /-->
  <node name="ground_finder_node" pkg="ground_finder" type="ground_finder_node" output="screen">
    <!-- Parameters -->
    <!-- param name="use_sim_time" value="true" type=""/ -->
    <param name="gf_quiet" value="$(arg gf_quiet)" type="bool"/>
    <param name="gf_filter" value="$(arg gf_filter)" type="string"/>
    <param name="gf_subcloud" value="$(arg gf_subcloud)" type="string"/>
    <param name="gf_plane" value="$(arg gf_plane)" type="string"/>
    <param name="gf_file" value="$(arg gf_file)" type="string"/>
    <param name="gf_enable_normal_smoothing" type="bool" value="$(arg gf_enable_normal_smoothing)" />
    <param name="gf_normal_smoothing_alpha" type="double" value="$(arg gf_normal_smoothing_alpha)" />
    <param name="gf_smoothing_cutoff_freq" type="double" value="$(arg gf_smoothing_cutoff_freq)" />
    <param name="gf_use_gaussian_smoothing" type="bool" value="$(arg gf_use_gaussian_smoothing)" />
    <param name="gf_weight_visibility" type="double" value="0.6" />
    <param name="gf_weight_inlier_ratio" type="double" value="0.4" />
    <param name="gf_score_threshold" value="0.2" type="double" />
    <param name="gf_min_score_sliding_window" value="0.3" type="double "/>
    <param name="gf_enable_scoring" value="$(arg gf_enable_scoring)" type="bool"/>
    <param name="gf_wall_threshold" value="$(arg gf_wall_threshold)" type="double"/>
    <param name="gf_enable_eigenvalue_validation" value="$(arg gf_enable_eigenvalue_validation)" type="bool"/>
    <param name="gf_eigenvalue_ratio_threshold" value="$(arg gf_eigenvalue_ratio_threshold)" type="double"/>
    <param name="gf_max_eigenvector_z_component" value="$(arg gf_max_eigenvector_z_component)" type="double"/>
    <param name="gf_enable_plane_angle_validation" value="$(arg gf_enable_plane_angle_validation)" type="bool"/>
    <param name="gf_enable_z_mean_validation" value="$(arg gf_enable_z_mean_validation)" type="bool"/>
    <param name="gf_max_z_deviation" value="$(arg gf_max_z_deviation)" type="double"/>
    <param name="gf_enable_convex_hull_validation" value="$(arg gf_enable_convex_hull_validation)" type="bool"/>
    <param name="gf_max_hull_distance" value="$(arg gf_max_hull_distance)" type="double"/>
    <param name="gf_timing_csv_enabled" value="$(arg gf_timing_csv_enabled)" type="bool"/>
    <param name="gf_timing_csv_file" value="$(arg gf_timing_csv_file)" type="string"/>
  </node>

</launch>
